{
  "rewrites": [
    {
      "source": "/tasks/(.*)",
      "destination": "/api/index.js"
    },
    {
      "source": "/tasks",
      "destination": "/api/index.js"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/index.js"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
