{
  "functions": {
    "api/index.cjs": {
      "memory": 128,
      "maxDuration": 10
    }
  },
  "rewrites": [
    {
      "source": "/tasks/(.*)",
      "destination": "/api/index.cjs"
    },
    {
      "source": "/tasks",
      "destination": "/api/index.cjs"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/index.cjs"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
